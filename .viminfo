	module adder_cla
	(
		input  [31:0] a,
		input  [31:0] b,
		input         cin,
		output        cout,
		output [31:0] sum
	);
	
		wire [6:0] co;
	
		adder_cla_4bit
		u_adder_cla_4bit0(
			.a					(a[3:0]				),
			.b					(b[3:0]				),
			.cin				(cin				),
			.cout				(co[0]				),
			.sum				(sum[3:0]			)
		);
	
		genvar i;
		generate
			for(i=1; i<7; i=i+1) begin : adder_cla_loop
				adder_cla_4bit
				u_adder_cla_4bit(
					.a					(a[4*i+3:4*i]		),
					.b					(b[4*i+3:4*i]		),
