	`define NVEC		8		// # of Test Vector
	
	// --------------------------------------------------
	//	Includes
	// --------------------------------------------------
	`include	"ALU.v"
	
	module ALU_tb;
	// --------------------------------------------------
	//	DUT Signals & Instantiate
	// --------------------------------------------------
		reg		 [2:0]  F;
		reg		 [31:0] A;
		reg		 [31:0] B;
		wire	 [31:0] ALUOut;
	
		ALU
		u_ALU(
			.F					(F					),
			.A					(A					),
			.B					(B					),
			.ALUOut				(ALUOut				)
		);
	
	// --------------------------------------------------
	//	Tasks
	// --------------------------------------------------
		reg [8*32-1:0] taskState;
	
		task init;
			begin
				F = 0;
				A = 0;
				B = 0;
			end
		endtask
	
	// --------------------------------------------------
	//	Test Stimulus
	// --------------------------------------------------
		integer		i, j;
		initial begin
			init();
	
			for (i=0; i<`SIMCYCLE; i++) begin
